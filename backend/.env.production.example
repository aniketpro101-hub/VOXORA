# === VOXORA PRODUCTION ENVIRONMENT CONFIGURATION ===
# MANDATORY: Generate strong 64-byte secret keys before starting!
# Run command in terminal to generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=voxora_prod_jwt_secret_change_me_immediately_2026
JWT_REFRESH_SECRET=voxora_prod_refresh_secret_change_me_immediately_2026

# MongoDB Connection String (No embedded credentials in code)
MONGO_URI=mongodb://localhost:27017/voxora

# Redis Configuration (Leave empty if no auth required)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# License System Secret Key
LICENSE_SECRET=voxora_production_license_master_secret_key

# Webhook Security Secret (For Evolution API / Baileys webhooks)
WEBHOOK_SECRET=voxora_webhook_secure_token_2026

# Allowed Frontend Origins (Comma separated list for CORS protection)
ALLOWED_ORIGINS=https://voxora.roasbodhi.in,http://localhost:3000,http://localhost:4000

# Server Port & Environment
PORT=4000
NODE_ENV=production
